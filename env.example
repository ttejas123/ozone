# Environment Variables — Ozone Service Providers
# Copy this file to .env.local and fill in the values for your chosen providers.
# All variables default to 'local' (browser-based) if not set.

# ─── Provider Selection ────────────────────────────────────────────────────────
# Options: local | supabase | firebase
VITE_DB_PROVIDER=local

# Options: local | supabase | r2 | s3
VITE_STORAGE_PROVIDER=local

# Options: worker | lambda | supabase-function
VITE_COMPUTE_PROVIDER=worker

# Options: local | cloudflare | node
VITE_REDIRECT_PROVIDER=local

# ─── Supabase (if VITE_DB_PROVIDER=supabase or VITE_STORAGE_PROVIDER=supabase) ─
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_STORAGE_BUCKET=uploads

# ─── Firebase (if VITE_DB_PROVIDER=firebase) ──────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_APP_ID=

# ─── Cloudflare R2 (if VITE_STORAGE_PROVIDER=r2) ─────────────────────────────
VITE_R2_ACCOUNT_ID=
VITE_R2_ACCESS_KEY_ID=
VITE_R2_SECRET_ACCESS_KEY=
VITE_R2_BUCKET_NAME=
VITE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── AWS S3 (if VITE_STORAGE_PROVIDER=s3) ────────────────────────────────────
VITE_S3_REGION=us-east-1
VITE_S3_ACCESS_KEY_ID=
VITE_S3_SECRET_ACCESS_KEY=
VITE_S3_BUCKET_NAME=
VITE_S3_PUBLIC_URL=https://your-bucket.s3.us-east-1.amazonaws.com

# ─── AWS Lambda (if VITE_COMPUTE_PROVIDER=lambda) ────────────────────────────
VITE_LAMBDA_COMPRESS_URL=https://api.example.com/compress
VITE_LAMBDA_DECOMPRESS_URL=https://api.example.com/decompress

# ─── Cloudflare Workers (if VITE_REDIRECT_PROVIDER=cloudflare) ───────────────
VITE_CLOUDFLARE_REDIRECT_API=https://redirect.your-worker.workers.dev

# ─── Node/REST API (if VITE_REDIRECT_PROVIDER=node) ─────────────────────────
VITE_REDIRECT_API_URL=https://api.example.com/redirect
